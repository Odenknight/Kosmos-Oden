.DS_Store
release/

# Generated build outputs — rebuilt by `npm run build`, attached to GitHub
# Releases by CI (not committed). The committed plugin components are only
# manifest.json + styles.css + versions.json (+ source). The standalone viewer
# (vault-kosmos.html) is a separate release download, kept out of the tracked
# tree so the plugin footprint stays clean. main.js is also generated (embeds
# the iframe page as base64) — rebuilding on Windows re-encodes its embedded
# HTML's line endings even with no source change, producing spurious diffs;
# it's rebuilt by CI and attached to each release like the rest.
vault-kosmos.html
dist/
main.js

# Obsidian plugin runtime data (contains the local Agent API token — never commit)
data.json

# Filled-in MCP client config holds the Agent API token — commit only .mcp.json.example
.mcp.json

# AI session handoff notes — local scratch, not part of the product
_Claude-Code/
AGENT.md

